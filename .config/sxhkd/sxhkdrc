#
# wm independent hotkeys
#

~button2
    ;echo -n | xclip -in

super + alt + y
  wezterm start -- zsh -ic 'yay && bspc wm -r'

# terminal emulator
super + Return
	wezterm

# program launcher
super + @space
	rofi -show drun

# make sxhkd reload its configuration files:
super + Escape
	pkill -USR1 -x sxhkd

# Take screen shot
super + shift + s
  mkdir -p ~/Pictures/Screenshots && \
  f=~/Pictures/Screenshots/$(date +%b%d_%H%M%S).png && \
  shotgun -g "$(slop)" "$f" && \
  xclip -selection clipboard -t image/png -i "$f"

#
# bspwm hotkeys
#

super + b 
  ~/.config/bspwm/scripts/browser   

super + r 
  ~/.config/bspwm/scripts/parsec  

super + shift + k 
  ~/.config/bspwm/scripts/cheatsheet

super + n
  ~/.config/bspwm/scripts/obsidian

# theme switcher (wallpaper + colors + login screen)
alt + t
  ~/.config/bspwm/scripts/theme

super + p 
  ~/.config/polybar/Scripts/power_menu.sh


# open file manager
super + e 
  thunar


# super + g
# 	wezterm start --class LazyGitTerminal -e lazygit

super + c 
  terax

super + i
  $HOME/.config/polybar/Scripts/ibus_toggle.sh toggle

# quit/restart bspwm
super + alt + {q,r}
	bspc {quit,wm -r}

# close and kill
super + w
	bspc node -c

super + shift + w
	bspc node -k

# alternate between the tiled and monocle layout
super + m
	bspc desktop -l next


#
# state/flags
#

# set the window state
super + {t,shift + t,s,f}
	bspc node -t {tiled,pseudo_tiled,floating,fullscreen}

# set the node flags

#
# focus/swap
#

# focus the node in the given direction
super + {_,shift + }{h,j,k,l}
	bspc node -{f,s} {west,south,north,east}

# focus the next/previous desktop in the current monitor
alt + {h, l}
	bspc desktop -f {prev,next}.local

# cycle desktop
super + Tab
  bspc desktop -f next.local 

super + shift + Tab
  bspc monitor -f next

# focus or send to the given desktop
super + {_,shift + }{1-9,0}
	bspc {desktop -f,node -d} '^{1-9,10}' --follow

#
# move/resize
#

# expand a window by moving one of its side outward
super + alt + {h,j,k,l}
	bspc node -z {left -20 0,bottom 0 20,top 0 -20,right 20 0}

# contract a window by moving one of its side inward
super + alt + shift + {h,j,k,l}
	bspc node -z {right -20 0,top 0 20,bottom 0 -20,left 20 0}

# move a floating window
super + {Left,Down,Up,Right}
	bspc node -v {-20 0,0 20,0 -20,20 0}

# enable/disable gap
super + {_, shift +} g
  bspc config window_gap {0,12}
  
# volume control
XF86AudioRaiseVolume
	pamixer -i 5

XF86AudioLowerVolume
	pamixer -d 5

XF86AudioMute
	pamixer -t

# laptop backlight
XF86MonBrightnessUp
	light -A 10

XF86MonBrightnessDown
	light -U 10
